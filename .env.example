# Database
DATABASE_URL=postgres://postgres:terusin@localhost:5432/terusin

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Auth (default user will be seeded on first run)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-in-production

# Backend
BACKEND_PORT=3011
MAX_RETRIES=5
DEFAULT_TARGET_URL=
ALLOW_PUBLIC_TARGET_OVERRIDE=false
ALLOW_PRIVATE_TARGETS=false
HOSTED_MODE=false
INGEST_CANONICAL_HOST=ingest.terusin-dev.my.id
# One-time bootstrap secret for the first platform operator. Never expose it to browsers.
PLATFORM_ADMIN_TOKEN=

# Google OAuth + invitation email (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The app's canonical browser URL. The OAuth callback defaults to
# $APP_URL/api/auth/callback/google.
APP_URL=http://localhost:5173
# Optional explicit overrides for a split frontend/backend deployment.
OAUTH_REDIRECT_URI=
FRONTEND_URL=
JWT_SECRET=change-me-in-production
# Required to send organization invitations through Resend.
RESEND_API_KEY=
EMAIL_FROM=Terusin <noreply@example.com>

# Web Dashboard
WEB_PORT=3012
BACKEND_URL=http://localhost:3011

# Ngrok (optional, for local development)
NGROK_PATH=ngrok
