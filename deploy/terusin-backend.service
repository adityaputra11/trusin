[Unit]
Description=Terusin Backend
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/terusin
EnvironmentFile=/opt/terusin/.env
ExecStart=/opt/terusin/bin/backend
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
