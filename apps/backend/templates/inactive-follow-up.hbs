<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <title>Ready to send your first webhook?</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f4f7f5;color:#17211b;font-family:Arial,Helvetica,sans-serif">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;background-color:#f4f7f5">
      <tr><td align="center" style="padding:40px 16px">
        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="width:100%;max-width:600px;background-color:#ffffff;border:1px solid #dce6df;border-radius:16px">
          <tr><td style="padding:28px 36px;background-color:#08100b;border-radius:16px 16px 0 0;border-top:4px solid #4ade80">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0"><tr>
              <td valign="middle" style="padding-right:10px"><img src="https://trusin.my.id/icon-trusin.png" width="32" height="32" alt="trusin" style="display:block;width:32px;height:32px;border:0;border-radius:8px"></td>
              <td valign="middle" style="color:#f4f7f5;font-size:22px;font-weight:700;letter-spacing:-0.5px;line-height:28px">trusin</td>
            </tr></table>
            <p style="margin:12px 0 0;color:#b6c4ba;font-size:13px;line-height:20px">Webhook operations</p>
          </td></tr>
          <tr><td style="padding:38px 36px 32px">
            <h1 style="margin:0 0 16px;color:#17211b;font-size:30px;font-weight:700;letter-spacing:-0.5px;line-height:38px">Ready when you are, {{display_name}}.</h1>
            <p style="margin:0;color:#516058;font-size:16px;line-height:26px">Your workspace is waiting. Add a provider, copy its endpoint, and send a test webhook to see trusin handle delivery end to end.</p>
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:28px 0 0"><tr><td align="center" bgcolor="#23c76b" style="border-radius:8px"><a href="{{app_url}}/providers?new=1" style="display:inline-block;padding:13px 20px;color:#062210;font-size:15px;font-weight:700;line-height:20px;text-decoration:none">Create a provider</a></td></tr></table>
          </td></tr>
          <tr><td style="padding:0 36px 30px"><table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border-top:1px solid #e6ede8"><tr><td style="padding-top:22px;color:#6b7a71;font-size:13px;line-height:20px">Need a hand? Follow the <a href="https://docs.trusin.my.id/docs/guides/webhook" style="color:#167a43;font-weight:700;text-decoration:underline">first webhook guide</a>.</td></tr></table></td></tr>
        </table>
        <p style="margin:18px 0 0;color:#809087;font-size:12px;line-height:18px">trusin · Reliable webhook delivery</p>
      </td></tr>
    </table>
  </body>
</html>
